{
	"name": "01factory",
	"version": "1.0.0",
	"scripts": {
		"release": "release-it",
		"sync": "git pull --no-edit git@e.coding.net:dfactory01/templates/base.git main"
	},
	"author": "taoqf <tao_qiufeng@126.com>",
	"license": "MIT",
	"release-it": {
		"npm": {
			"publish": false
		},
		"plugins": {
			"@release-it/conventional-changelog": {
				"infile": "CHANGELOG.md",
				"header": "# Changelog",
				"preset": {
					"name": "conventionalcommits",
					"types": [
						{
							"type": "feat",
							"section": "Features"
						},
						{
							"type": "fix",
							"section": "Bug Fixes"
						}
					]
				},
				"strictSemVer": true
			}
		}
	},
	"devDependencies": {
		"@release-it/conventional-changelog": "^8.0.1",
		"release-it": "^17.1.1"
	}
}
