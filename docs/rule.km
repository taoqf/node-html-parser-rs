{
    "root": {
        "data": {
            "id": "d18yumbg90g0",
            "created": 1715649105286,
            "text": "规范",
            "expandState": "expand"
        },
        "children": [
            {
                "data": {
                    "id": "d18zjd6rtls0",
                    "created": 1715651044516,
                    "text": "代码规范",
                    "expandState": "expand"
                },
                "children": [
                    {
                        "data": {
                            "id": "d18yva7wv4w0",
                            "created": 1715649157315,
                            "text": "命名规则"
                        },
                        "children": [
                            {
                                "data": {
                                    "id": "d18z16enhts0",
                                    "created": 1715649619200,
                                    "text": "目录/文件名称",
                                    "note": "小写英文+数字组成。多个单词使用`-`分隔。如`search-data`。"
                                },
                                "children": []
                            },
                            {
                                "data": {
                                    "id": "d18z3j78wyo0",
                                    "created": 1715649803779,
                                    "text": "变量",
                                    "note": "蛇型 `a_b` 或小驼峰 `aB'"
                                },
                                "children": []
                            },
                            {
                                "data": {
                                    "id": "d18z44sqg800",
                                    "created": 1715649850790,
                                    "text": "函数",
                                    "note": "小驼峰。示例： get-date.ts 中导出默认函数\n\n```ts\nexport default getDate(){}\n```"
                                },
                                "children": []
                            },
                            {
                                "data": {
                                    "id": "d19ss12tfjc0",
                                    "created": 1715733535620,
                                    "text": "方法",
                                    "note": null
                                },
                                "children": [
                                    {
                                        "data": {
                                            "id": "d19ssmxzis80",
                                            "created": 1715733583217,
                                            "text": "公有方法",
                                            "note": "对象成员方法命名方式与函数相同。"
                                        },
                                        "children": []
                                    },
                                    {
                                        "data": {
                                            "id": "d19ssv6js9s0",
                                            "created": 1715733601149,
                                            "text": "私有方法",
                                            "note": "方法名前加下划线 `_` 以区分。"
                                        },
                                        "children": []
                                    }
                                ]
                            },
                            {
                                "data": {
                                    "id": "d18z4aleqns0",
                                    "created": 1715649863408,
                                    "text": "类型定义",
                                    "note": "大驼峰"
                                },
                                "children": []
                            },
                            {
                                "data": {
                                    "id": "d18z4qlpzew0",
                                    "created": 1715649898256,
                                    "text": "组件",
                                    "note": "大驼峰。如`MyComp`。示例： my-comp.tsx 中导出默认函数\n\n```ts\nexport default MyComp(){}\n```"
                                },
                                "children": []
                            },
                            {
                                "data": {
                                    "id": "d191lhafag80",
                                    "created": 1715656852392,
                                    "text": "数据库"
                                },
                                "children": [
                                    {
                                        "data": {
                                            "id": "d191likqlrc0",
                                            "created": 1715656855192,
                                            "text": "表名",
                                            "note": "小写英文+数字组成。多个单词使用`_`分隔。如`search_data`。"
                                        },
                                        "children": []
                                    },
                                    {
                                        "data": {
                                            "id": "d191lq8fty80",
                                            "created": 1715656871863,
                                            "text": "字段名",
                                            "note": "小写英文+数字组成。多个单词使用`_`分隔。如`search_data`。"
                                        },
                                        "children": []
                                    },
                                    {
                                        "data": {
                                            "id": "d191lusude80",
                                            "created": 1715656881804,
                                            "text": "主键",
                                            "note": "前面加上表主体名字，不同表的id字段名要尽可能不同，示例：\n\n1.  用户表(user)主键：`userid` \n1.  订单表(order)主键：`orderid`\n"
                                        },
                                        "children": []
                                    }
                                ]
                            },
                            {
                                "data": {
                                    "id": "d18zcfqlb5c0",
                                    "created": 1715650501519,
                                    "text": "常用英文简拼",
                                    "note": "简拼|全拼\n---|---\n`I`|interface\n`db`|database\n`dt`|date\n`2`|to\n`4`|for\n`Tb`|table\n`v`|view\n`str`|string\n`no`|number\n`num`|number\n"
                                },
                                "children": []
                            },
                            {
                                "data": {
                                    "id": "d195jpvr5rs0",
                                    "created": 1715667998807,
                                    "text": "拼音 vs 英文",
                                    "note": null,
                                    "expandState": "collapse"
                                },
                                "children": [
                                    {
                                        "data": {
                                            "id": "d195oju05y80",
                                            "created": 1715668377462,
                                            "text": "优先级"
                                        },
                                        "children": [
                                            {
                                                "data": {
                                                    "id": "d195om2snyw0",
                                                    "created": 1715668382347,
                                                    "text": "英文",
                                                    "note": "英文的可读性较强，但也仅限于常规词汇。"
                                                },
                                                "children": []
                                            },
                                            {
                                                "data": {
                                                    "id": "d195onguq0g0",
                                                    "created": 1715668385374,
                                                    "text": "拼音",
                                                    "note": "在很多时候，拼音的可读性还会甚于英文，毕竟现在的开发人员不都是英文大量。"
                                                },
                                                "children": []
                                            },
                                            {
                                                "data": {
                                                    "id": "d195oosixi80",
                                                    "created": 1715668388256,
                                                    "text": "汉字",
                                                    "note": "如果开发人员英文不好，起名字有困难时，甚至可以直接使用汉字作为变量名,如:\n\n```ts\nconst 订单数量= 123;\n```\n\n代码依然具有非常好的可读性，只可惜代码书写速度较慢。\n"
                                                },
                                                "children": []
                                            }
                                        ]
                                    },
                                    {
                                        "data": {
                                            "id": "d195otdtw680",
                                            "created": 1715668398251,
                                            "text": "禁止使用无意义变量名",
                                            "note": "原则上禁止使用无意义名称作为变量名，如:\n\n```ts\nconst a = 123;\n```\n"
                                        },
                                        "children": []
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "data": {
                            "id": "d18ywwrs2r40",
                            "created": 1715649284770,
                            "text": "接口",
                            "note": "使用`type`替代`interface`。\n\n示例：\n\n```ts\ninterface IBase {\n\tid: number;\n\tname: string;\n}\ninterface IType extends IBase {\n\ttype: string;\n}\n```\n\n可用以下方式替代：\n\n```ts\ntype Base = {\n\tid: number;\n\tname: string;\n};\ntype Type = Base & {\n\ttype: string;\n};\n```"
                        },
                        "children": []
                    },
                    {
                        "data": {
                            "id": "d18yxfsogg00",
                            "created": 1715649326183,
                            "text": "文本枚举",
                            "note": "文本枚举使用`enum`替代`const`。\n\n示例：\n\n```ts\nenum Status {\n\tSuccess = 'success',\n\tFail = 'fail',\n}\n```\n\n可用以下方式替代：\n\n```ts\nconst Status = 'success' | fail';\n```\n"
                        },
                        "children": []
                    },
                    {
                        "data": {
                            "id": "d18z4qlpzew0",
                            "created": 1715649898256,
                            "text": "组件",
                            "note": null,
                            "expandState": "expand"
                        },
                        "children": [
                            {
                                "data": {
                                    "id": "d18zarkyhc80",
                                    "created": 1715650370571,
                                    "text": "一个文件只导出一个组件"
                                },
                                "children": []
                            },
                            {
                                "data": {
                                    "id": "d18zba7i6dk0",
                                    "created": 1715650411117,
                                    "text": "显示隐藏"
                                },
                                "children": [
                                    {
                                        "data": {
                                            "id": "d18zbqugyi80",
                                            "created": 1715650447334,
                                            "text": "根据数据条件控制",
                                            "note": "使用 `{cond && <Component></Component>}`方式"
                                        },
                                        "children": []
                                    },
                                    {
                                        "data": {
                                            "id": "d18zbv1uv940",
                                            "created": 1715650456488,
                                            "text": "根据用户操作控制",
                                            "note": "使用 `<Component visible={visible}></Component>`方式，如：新增/编辑/详情等弹出框组件."
                                        },
                                        "children": []
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "data": {
                            "id": "d18z87a9izk0",
                            "created": 1715650169661,
                            "text": "lambda",
                            "expandState": "expand"
                        },
                        "children": [
                            {
                                "data": {
                                    "id": "d18z8ftocc00",
                                    "created": 1715650188249,
                                    "text": "箭头函数不允许省略小括号"
                                },
                                "children": []
                            },
                            {
                                "data": {
                                    "id": "d18z8n9isco0",
                                    "created": 1715650204444,
                                    "text": "箭头函数不允许省略大括号"
                                },
                                "children": []
                            },
                            {
                                "data": {
                                    "id": "d18z8q8rew80",
                                    "created": 1715650210930,
                                    "text": "示例",
                                    "note": "错误的写法：\n\n```ts\n[1,2,3].map(it=>it.toString());\n```\n\n正确的写法：\n\n```ts\n[1,2,3].map((it)=>{\n\treturn it.toString();\n});\n```\n"
                                },
                                "children": []
                            }
                        ]
                    },
                    {
                        "data": {
                            "id": "d18zjusc2b40",
                            "created": 1715651082825,
                            "text": "let",
                            "expandState": "expand"
                        },
                        "children": [
                            {
                                "data": {
                                    "id": "d18zjxeh7mw0",
                                    "created": 1715651088518,
                                    "text": "原则上禁用let",
                                    "note": "for 循环中的循环变量例外，但for循环语法亦不推荐。循环推荐使用数据库的 `forEach`,`map`等方法。"
                                },
                                "children": []
                            },
                            {
                                "data": {
                                    "id": "d18zku2wfmo0",
                                    "created": 1715651159651,
                                    "text": "使用const代替",
                                    "note": "不允许修改变量，示例\n```ts\nlet a = 1;\nif (b) {\n\ta = 2;\n}\n```\n\n应写为\n\n```ts\nconst a = b ? 2 : 1;\n```\n\n或\n\n```ts\nconst a = (()=>{\n\tif(b){\n    \treturn 2;\n    } else {\n    \treturn 1;\n    }\n})();\n```\n"
                                },
                                "children": []
                            },
                            {
                                "data": {
                                    "id": "d18zn9ddlao0",
                                    "created": 1715651349665,
                                    "text": "成员变量修改",
                                    "note": "对象的成员变量也不允许修改,示例：\n\n```ts\nconst reply = {\n\tfoo: 1,\n    bar: 'abc'\n};\n\n...业务逻辑代码\nreply.foo = 2;\n...业务逻辑代码\n\nreturn reply;\n```\n\n应写为:\n\n```ts\nconst foo = con1 ? 1 : 2;\n\n...业务逻辑代码\nconst reply = {\n\tbar: 'abc',\n    foo\n};\n```\n或\n```ts\nconst foo = (()=>{\n\tif (con1){\n    \treturn 1;\n    } else {\n    \treturn 2;\n    }\n})();\n\n...业务逻辑代码\nconst reply = {\n\tbar: 'abc',\n    foo\n};\n```\n"
                                },
                                "children": []
                            }
                        ]
                    },
                    {
                        "data": {
                            "id": "d18zr1riqgo0",
                            "created": 1715651646562,
                            "text": "全局变量",
                            "expandState": "expand"
                        },
                        "children": [
                            {
                                "data": {
                                    "id": "d18zr4hobpk0",
                                    "created": 1715651652497,
                                    "text": "一般地，禁用全局变量"
                                },
                                "children": []
                            },
                            {
                                "data": {
                                    "id": "d18zrez1rts0",
                                    "created": 1715651675316,
                                    "text": "小程序端使用storage代替，并严格规范使用"
                                },
                                "children": []
                            },
                            {
                                "data": {
                                    "id": "d18zru2cmt40",
                                    "created": 1715651708167,
                                    "text": "web/h5端使用localstorage代替，并严格规范使用"
                                },
                                "children": []
                            }
                        ]
                    },
                    {
                        "data": {
                            "id": "d191xo22sc80",
                            "created": 1715657807495,
                            "text": "注释",
                            "expandState": "expand"
                        },
                        "children": [
                            {
                                "data": {
                                    "id": "d191xponrpc0",
                                    "created": 1715657811037,
                                    "text": "函数",
                                    "note": null,
                                    "expandState": "expand"
                                },
                                "children": [
                                    {
                                        "data": {
                                            "id": "d1921546zso0",
                                            "created": 1715658079721,
                                            "text": "块注释"
                                        },
                                        "children": [
                                            {
                                                "data": {
                                                    "id": "d19216uyiy80",
                                                    "created": 1715658083516,
                                                    "text": "首行一个斜杠加两个星号`/**`"
                                                },
                                                "children": []
                                            },
                                            {
                                                "data": {
                                                    "id": "d1921gfdtk00",
                                                    "created": 1715658104342,
                                                    "text": "中间行与首行对齐后，一个空格加一个星号开头，再加一个空格与注释文本隔开` * `"
                                                },
                                                "children": []
                                            },
                                            {
                                                "data": {
                                                    "id": "d1921ucse6w0",
                                                    "created": 1715658134660,
                                                    "text": "末行一个空格，一个星号加一个斜杠` */`"
                                                },
                                                "children": []
                                            }
                                        ]
                                    },
                                    {
                                        "data": {
                                            "id": "d1922an7s2w0",
                                            "created": 1715658170119,
                                            "text": "函数说明",
                                            "note": "对函数的功能进行简要说明"
                                        },
                                        "children": []
                                    },
                                    {
                                        "data": {
                                            "id": "d1922j13uw80",
                                            "created": 1715658188373,
                                            "text": "参数说明",
                                            "note": "1. 可选\n1. 一般不需要\n1. 不需要在注释中声明参数类型\n1. 特殊难于理解的要注明参数。格式为\n\n```\n@param 参数名 参数说明\n```"
                                        },
                                        "children": []
                                    },
                                    {
                                        "data": {
                                            "id": "d192a416ixs0",
                                            "created": 1715658782639,
                                            "text": "返回值说明",
                                            "note": "1. 可选\n1. 一般不需要\n1. 不需要在注释中声明返回值类型\n1. 特殊难于理解的要注明返回值。格式为\n\n```\n@returns 返回值说明\n```"
                                        },
                                        "children": []
                                    },
                                    {
                                        "data": {
                                            "id": "d19263azd5k0",
                                            "created": 1715658467598,
                                            "text": "换行"
                                        },
                                        "children": [
                                            {
                                                "data": {
                                                    "id": "d19265417wo0",
                                                    "created": 1715658471532,
                                                    "text": "如果说明文本过长，需要换行描述"
                                                },
                                                "children": []
                                            }
                                        ]
                                    },
                                    {
                                        "data": {
                                            "id": "d1921ylvtdk0",
                                            "created": 1715658143917,
                                            "text": "示例",
                                            "note": "```ts\n/**\n * 这是一个函数注释,注释内容有点儿长\n * 更多的说明换一行写\n * @param param2 这个参数不好理解，\n * 在这里进行详细解释。另外这个参数\n * 的说明也有点儿长，这里添加换行说明\n * @returns 返回值说明，一般不需要\n */\nfunction myFun(param1: Type1, param2: Type2){\n}\n```"
                                        },
                                        "children": []
                                    }
                                ]
                            },
                            {
                                "data": {
                                    "id": "d1928cq985c0",
                                    "created": 1715658644841,
                                    "text": "对象",
                                    "expandState": "expand"
                                },
                                "children": [
                                    {
                                        "data": {
                                            "id": "d192c8suty80",
                                            "created": 1715658949748,
                                            "text": "对象说明",
                                            "note": "使用块注释"
                                        },
                                        "children": []
                                    },
                                    {
                                        "data": {
                                            "id": "d191xveq5m00",
                                            "created": 1715657823497,
                                            "text": "成员方法",
                                            "note": "同函数"
                                        },
                                        "children": []
                                    },
                                    {
                                        "data": {
                                            "id": "d191xwfoq2o0",
                                            "created": 1715657825732,
                                            "text": "成员变量",
                                            "note": "除了没有参数和返回值之外，与函数的注释规范一致。"
                                        },
                                        "children": []
                                    }
                                ]
                            },
                            {
                                "data": {
                                    "id": "d1928dwvykg0",
                                    "created": 1715658647419,
                                    "text": "类型",
                                    "note": "同对象"
                                },
                                "children": []
                            },
                            {
                                "data": {
                                    "id": "d191xylnfww0",
                                    "created": 1715657830446,
                                    "text": "功能",
                                    "note": null
                                },
                                "children": [
                                    {
                                        "data": {
                                            "id": "d192ditfwkg0",
                                            "created": 1715659049915,
                                            "text": "行注释"
                                        },
                                        "children": [
                                            {
                                                "data": {
                                                    "id": "d192dzf119c0",
                                                    "created": 1715659086049,
                                                    "text": "两个斜杠后跟一个空格",
                                                    "note": null
                                                },
                                                "children": []
                                            }
                                        ]
                                    },
                                    {
                                        "data": {
                                            "id": "d192dmpope00",
                                            "created": 1715659058395,
                                            "text": "功能性描述",
                                            "note": "对代码的功能逻辑进行描述。这往往是比流程图逻辑更细，但直接从阅读代码本身看不出来的内容。"
                                        },
                                        "children": []
                                    }
                                ]
                            },
                            {
                                "data": {
                                    "id": "d192d9n9xr40",
                                    "created": 1715659029951,
                                    "text": "代码"
                                },
                                "children": [
                                    {
                                        "data": {
                                            "id": "d192fnc7zts0",
                                            "created": 1715659216486,
                                            "text": "废弃代码",
                                            "note": "一般这种注释是一部分暂时不用，但有可能以后备用的代码，开发人员会将其注释掉。\n使用行注释"
                                        },
                                        "children": []
                                    }
                                ]
                            }
                        ]
                    }
                ]
            },
            {
                "data": {
